# SQL
SQL_SERVER_URL=
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_MAIN_DB=
SQL_GOLEM_DB=
SQL_RUNE_DB=

# AUTH
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MODULES
## RUNE
NOTION_API_KEY=

# RATE LIMITING
GENERATION_WINDOW_HOURS=24

# LLM (supported: claude-code, local)
LLM_PROVIDER=
LLM_SERVER_URL=
LLM_MODEL=
KEEP_TEMP_FILES=false # Keep .tmp/ output files for debugging
NEXT_PUBLIC_GENERATION_POLL_INTERVAL_MS=10000 # How often the client checks for completion of a generation job

# PIPER TTS
PIPER_BINARY_PATH=
PIPER_MODEL_PATH= # Voice model .onnx file (e.g. en_US-amy-medium.onnx)
PIPER_LENGTH_SCALE=1.0 # Speech rate (< 1.0 = faster, > 1.0 = slower)
PIPER_SENTENCE_SILENCE=0.2 # Pause between sentences in seconds

# WHISPER STT
WHISPER_BINARY_PATH=
WHISPER_MODEL_PATH=
NEXT_PUBLIC_SILENCE_TIMEOUT_MS=5000 # Auto-stop recording after this much silence